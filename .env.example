PORT=3000

# PostgreSQL Connection String (Supabase/Neon)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Brevo API Key
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM_EMAIL=your_brevo_verified_sender_email_here

# Admin Settings
# Plain text password that you will use to log in (the backend will verify it)
ADMIN_PASSWORD=admin1234
JWT_SECRET=super_secret_jwt_signing_key_change_me

# Cron Security Token
CRON_SECRET=super_secret_cron_token_change_me
